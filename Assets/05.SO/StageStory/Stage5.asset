  Lines:
  - CharacterIndex: 0
    Sentence: "5\uC2A4\uD14C\uC774\uC9C0 -(\uC11D\uC720)"
    HasSoundEffect: 0
    SoundEffect: 0
  - CharacterIndex: 0
    Sentence: "\uBC30\uACBD: \uC190\uC0C1\uB41C \uC7A0\uC218\uD568 \uB0B4\uBD80"
    HasSoundEffect: 0
    SoundEffect: 0
  - CharacterIndex: 2
    Sentence: "\uBB3C \uC0C9\uC774\u2026 \uAC80\uAC8C \uBCC0\uD558\uACE0 \uC788\uC5B4\uC694."
    HasSoundEffect: 0
    SoundEffect: 0
  - CharacterIndex: 1
    Sentence: "\uC11D\uC720 \uC720\uCD9C\uC774\uB2E4! \uC808\uB300 \uC11D\uC720\uCE35\uC5D0
      \uB4E4\uC5B4\uAC00\uC9C0 \uB9C8. \uC5D4\uC9C4\uACFC \uC678\uBCBD\uC774 \uB9DD\uAC00\uC838."
    HasSoundEffect: 0
    SoundEffect: 0
  - CharacterIndex: 2
    Sentence: "\uD558\uC9C0\uB9CC \uAE38\uC774 \uB9C9\uD614\uC5B4\uC694\u2026"
    HasSoundEffect: 0
    SoundEffect: 0
  - CharacterIndex: 1
    Sentence: "\uC800\uCABD\uC740 \uB35C \uD37C\uC9C4 \uAC83 \uAC19\uC544. \uC800\uCABD\uC73C\uB85C
      \uAC00\uC790. \uC11D\uC720\uAC00 \uB354 \uD37C\uC9C0\uAE30 \uC804\uC5D0 \uC11D\uC720
      \uB369\uC5B4\uB9AC\uB97C \uD53C\uD574\uC11C \uC774\uB3D9\uD574\uC57C \uD560
      \uAC83 \uAC19\uC544!"
    HasSoundEffect: 0
    SoundEffect: 0
