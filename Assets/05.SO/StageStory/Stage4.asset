  Characters:
  - Name: "\uB098\uB808\uC774\uC158"
    Sprite: {fileID: -776501124, guid: ea337a04be4df094ea6e7d4467b52ad1, type: 3}
  - Name: "\uC8FC\uC778\uACF5"
    Sprite: {fileID: -1892686050, guid: def74e369b3b6614985a33db90c2b4e1, type: 3}
  - Name: "\uB3D9\uB8CC"
    Sprite: {fileID: -290104245, guid: 4de254a1672fd1c4da8fee3c495bcf9b, type: 3}
  - Name: "\uD6A8\uACFC\uC74C"
    Sprite: {fileID: 0}
  Lines:
  - CharacterIndex: 0
    Sentence: "4\uC2A4\uD14C\uC774\uC9C0 -(\uC720\uB9AC\uBCD1)"
    HasSoundEffect: 0
    SoundEffect: 0
  - CharacterIndex: 0
    Sentence: "\uBC30\uACBD: \uC190\uC0C1\uB41C \uC7A0\uC218\uD568 \uB0B4\uBD80"
    HasSoundEffect: 0
    SoundEffect: 0
  - CharacterIndex: 2
    Sentence: "\uC800\uAE30\u2026 \uD558\uC580 \uBE5B\uC774 \uACC4\uC18D \uBC18\uC9DD\uC774\uB294\uB370\uC694?"
    HasSoundEffect: 0
    SoundEffect: 0
  - CharacterIndex: 0
    Sentence: "\uAC15\uB82C\uD55C \uD558\uC580 \uC12C\uAD11\uC774 \uC7A0\uC218\uD568\uC744
      \uB36E\uCE5C\uB2E4. \uC218\uB9CE\uC740 \uC720\uB9AC\uBCD1\uB4E4\uC774 \uBE5B\uC744
      \uBC18\uC0AC\uD574 \uB208\uC774 \uBD80\uC2E4 \uC815\uB3C4\uB2E4."
    HasSoundEffect: 0
    SoundEffect: 0
  - CharacterIndex: 1
    Sentence: "\uB108\uBB34 \uBC1D\uC544! \uC55E\uC774 \uC548 \uBCF4\uC5EC!"
    HasSoundEffect: 0
    SoundEffect: 0
  - CharacterIndex: 3
    Sentence: "\uCA0D\uADF8\uB791!"
    HasSoundEffect: 1
    SoundEffect: 10
  - CharacterIndex: 0
    Sentence: "\uC720\uB9AC\uBCD1\uC774 \uBD80\uB52A\uD788\uBA70 \uC678\uBCBD\uC5D0
      \uAD6C\uBA4D\uC774 \uB6AB\uB9AC\uACE0 \uBB3C\uC774 \uC3DF\uC544\uC838 \uB4E4\uC5B4\uC628\uB2E4."
    HasSoundEffect: 0
    SoundEffect: 0
  - CharacterIndex: 2
    Sentence: "\uC5B4\uD478! \uBB3C \uB4E4\uC5B4\uC640\uC694!!"
    HasSoundEffect: 0
    SoundEffect: 0
  - CharacterIndex: 1
    Sentence: "\uC5BC\uB978 \uB9C9\uC544\uC57C \uD574! \uB0B4\uAC00 \uB9C9\uACE0
      \uC788\uC744 \uD14C\uB2C8 \uB108\uB294 \uC5BC\uB978 \uC870\uC885\uD574!"
    HasSoundEffect: 0
    SoundEffect: 0
