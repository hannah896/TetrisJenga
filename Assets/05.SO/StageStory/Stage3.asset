  m_Script: {fileID: 11500000, guid: 2150504852ee59e4496ad5828adc5b60, type: 3}
  m_Name: Stage3
  m_EditorClassIdentifier: Assembly-CSharp::Dialogue
  Characters:
  - Name: "나레이션"
    Sprite: {fileID: 0}
  - Name: "주인공"
    Sprite: {fileID: 0}
  - Name: "동료"
    Sprite: {fileID: 0}
  - Name: "효과음"
    Sprite: {fileID: 0}
  Lines:
  - CharacterIndex: 0
    Sentence: "3스테이지 - (비닐봉지)"
  - CharacterIndex: 0
    Sentence: "배경: 손상된 잠수함 내부"
  - CharacterIndex: 0
    Sentence: "갑자기 내부가 완전히 깜깜해진다."
  - CharacterIndex: 2
    Sentence: "뭐지? 시스템이 나간 건가?"
  - CharacterIndex: 1
    Sentence: "(손전등 켜며) 아니야. 창문을 봐."
  - CharacterIndex: 0
    Sentence: "검은 비닐봉지들이 유리창과 외벽에 빽빽하게 붙어 빛을 막고 있다."
  - CharacterIndex: 1
    Sentence: "비닐봉지들이야…"
  - CharacterIndex: 1
    Sentence: "나가서 제거해야 할 것 같아."
  - CharacterIndex: 2
    Sentence: "지금 라이트도 비닐봉지에 감싸진 것 같은데 위험할 것 같아요."
  - CharacterIndex: 3
    Sentence: "띠잉! 띠잉"
  - CharacterIndex: 0
    Sentence: "잠수함에 해류 경고등이 울린다."
  - CharacterIndex: 2
    Sentence: "어떡하죠?"
